{
  "name": "bh-web",
  "version": "1.1.15",
  "description": "BetterHilongos.org - Official Portal for LGU Hilongos",
  "scripts": {
    "dev": "node server.js",
    "build": "bash build.sh",
    "build:major": "bash scripts/version.sh major && bash build.sh --no-bump",
    "build:minor": "bash scripts/version.sh minor && bash build.sh --no-bump",
    "serve": "python3 -m http.server 8888",
    "serve:dist": "cd dist && python3 -m http.server 8080",
    "version:major": "node scripts/bump-version.js major",
    "version:minor": "node scripts/bump-version.js minor",
    "version:patch": "node scripts/bump-version.js patch",
    "version:check": "node scripts/bump-version.js",
    "lighthouse": "lhci autorun",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "hilongos",
    "leyte",
    "government",
    "lgu"
  ],
  "author": "Rolf Genree Garces",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.23.9",
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@lhci/cli": "^0.15.1",
    "clean-css-cli": "^5.6.3",
    "core-js": "^3.40.0",
    "express": "^4.18.2",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.8.1",
    "terser": "^5.44.1"
  },
  "overrides": {
    "tmp": "0.2.5"
  }
}
